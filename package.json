{
  "name": "@gran-paso/ui",
  "version": "0.1.8",
  "description": "Gran Paso ERP shared component library and design system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme/tailwind-preset": {
      "types": "./dist/theme/tailwind-preset.d.ts",
      "import": "./dist/theme/tailwind-preset.js",
      "require": "./dist/theme/tailwind-preset.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "lint": "eslint src/",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "framer-motion": ">=10.0.0",
    "lucide-react": ">=0.300.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "framer-motion": "^12.6.0",
    "lucide-react": "^0.475.0",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.3",
    "storybook": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gran-paso/gp-ui.git"
  },
  "license": "UNLICENSED",
  "sideEffects": [
    "**/*.css"
  ]
}
